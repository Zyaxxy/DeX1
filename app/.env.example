# Solana Configuration
NEXT_PUBLIC_CLUSTER=devnet
RPC_URL=https://api.devnet.solana.com
# RPC_URLS=https://api.devnet.solana.com (Optional: Comma-separated fallback RPC URLs)

# Admin Credentials
ADMIN_PASSWORD=your_secure_admin_panel_password
ADMIN_PRIVATE_KEY=[1,2,3,...] # Keypair JSON array or Base58 string for FsHawHBmgvn5uGZHDWt2NQMbpFGFnCqiC4Knmw31NCrr

# Keeper Settings (for processing claims in API routes)
KEEPER_PRIVATE_KEY=[1,2,3,...] # Secret key for 6gUa3Yreg3rgt6PoXkm6CL6TGBbTrdxeeGkeZZoeEbMm

# TxLINE Sports API Integration
TXLINE_JWT=your_txline_jwt_here
TXLINE_API_TOKEN=your_txline_api_token_here
TXLINE_BASE_URL=https://txline-dev.txodds.com

# Database Connection (Neon PostgreSQL)
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Cron Security (for securing keeper cron API endpoints)
CRON_SECRET=your_cron_secret_here
