# Solana Network Configuration
RPC_URL=https://api.devnet.solana.com

# Keeper Private Key (Authorized to lock & settle contests; e.g. 6gUa3Yreg3rgt6PoXkm6CL6TGBbTrdxeeGkeZZoeEbMm)
# Can be configured as a base58 encoded string or a JSON number array
KEEPER_PRIVATE_KEY=your_private_key_here

# TxLINE Sports API Credentials
TXLINE_JWT=your_txline_jwt_here
TXLINE_API_TOKEN=your_txline_api_token_here
TXLINE_BASE_URL=https://txline-dev.txodds.com

# Database Connection (Neon PostgreSQL - if required for local indexing or caching)
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

